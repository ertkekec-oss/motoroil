model TargetPlan {
  id               String            @id @default(cuid())
  companyId        String
  tenantId         String
  year             Int
  totalTarget      Decimal           @db.Decimal(12, 2)
  bonusPool        Decimal           @db.Decimal(12, 2)
  status           String            @default("ACTIVE") // ACTIVE, DRAFT, CLOSED
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  periods          TargetPeriod[]
  assignments      TargetAssignment[]
  suggestions      AITargetSuggestion[]

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model TargetPeriod {
  id               String            @id @default(cuid())
  planId           String
  name             String            // Q1, Q2, Q3, Q4
  startDate        DateTime
  endDate          DateTime
  target           Decimal           @db.Decimal(12, 2)
  bonus            Decimal           @db.Decimal(12, 2)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  plan             TargetPlan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  assignments      TargetAssignment[]
}

model TargetAssignment {
  id               String            @id @default(cuid())
  planId           String
  periodId         String
  staffId          String
  target           Decimal           @db.Decimal(12, 2)
  bonusPotential   Decimal           @db.Decimal(12, 2)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  plan             TargetPlan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  period           TargetPeriod      @relation(fields: [periodId], references: [id], onDelete: Cascade)
  staff            Staff             @relation(fields: [staffId], references: [id], onDelete: Cascade)
  performances     Performance[]
  bonusResults     BonusResult[]
}

model Performance {
  id               String            @id @default(cuid())
  assignmentId     String
  actual           Decimal           @db.Decimal(12, 2)
  achievement      Decimal           @db.Decimal(5, 4) // Example: 1.0500 for 105%
  isCumulative     Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  assignment       TargetAssignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

model BonusResult {
  id               String            @id @default(cuid())
  assignmentId     String
  baseBonus        Decimal           @db.Decimal(12, 2)
  accelerator      Decimal           @db.Decimal(5, 2) // Example: 1.20
  finalBonus       Decimal           @db.Decimal(12, 2)
  isRecovered      Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  assignment       TargetAssignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

model AchievementBadge {
  id               String            @id @default(cuid())
  staffId          String
  badgeType        String            // FIRST_SALE, TARGET_CRUSHER, CONSISTENCY, RAINMAKER
  earnedAt         DateTime          @default(now())
  streakCount      Int               @default(0) // 3, 6 vs
  
  staff            Staff             @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model LeaderboardScore {
  id               String            @id @default(cuid())
  companyId        String
  periodId         String            // Q1 vs
  staffId          String
  rank             Int
  scoreType        String            // HIGHEST_SALES, HIGHEST_GROWTH, HIGHEST_ACHIEVEMENT
  scoreValue       Decimal           @db.Decimal(12, 2)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  
  staff            Staff             @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model AITargetSuggestion {
  id               String            @id @default(cuid())
  planId           String
  safeTarget       Decimal           @db.Decimal(12, 2)
  balancedTarget   Decimal           @db.Decimal(12, 2)
  aggressiveTarget Decimal           @db.Decimal(12, 2)
  analysisData     Json?             // trend details
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  plan             TargetPlan        @relation(fields: [planId], references: [id], onDelete: Cascade)
}
