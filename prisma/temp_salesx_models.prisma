model SalesXInsight {
  id               String            @id @default(cuid())
  tenantId         String
  companyId        String
  type             String            // INFO, WARNING, OPPORTUNITY, RECOMMENDATION
  title            String
  description      String
  category         String            // REACTIVATION, UPSELL, ROUTE_OPTIMIZATION, RISK
  referenceId      String?
  targetStaffId    String?
  isRead           Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  staff            Staff?            @relation(fields: [targetStaffId], references: [id], onDelete: SetNull)
}

model SalesXOpportunity {
  id               String            @id @default(cuid())
  tenantId         String
  companyId        String
  customerId       String
  opportunityType  String            // REACTIVATION, UPSELL, CATEGORY_EXPANSION, HIGH_POTENTIAL
  title            String
  description      String
  potentialValue   Decimal           @db.Decimal(12, 2)
  priorityScore    Int               @default(0) // 0 - 100
  status           String            @default("OPEN") // OPEN, IN_PROGRESS, WON, LOST
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model PredictiveVisit {
  id               String            @id @default(cuid())
  tenantId         String
  companyId        String
  customerId       String
  suggestedDate    DateTime
  priorityScore    Int               // 0 - 100
  reason           String            // e.g. "90 gündür ziyaret edilmedi, yüksek potansiyel"
  status           String            @default("SUGGESTED") // SUGGESTED, PLANNED, REGECTED
  assignedStaffId  String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  staff            Staff?            @relation(fields: [assignedStaffId], references: [id], onDelete: SetNull)
}

model RouteSuggestion {
  id               String            @id @default(cuid())
  tenantId         String
  companyId        String
  staffId          String
  planDate         DateTime
  routeData        Json              // Ordered array of customer optimization
  estimatedValue   Decimal           @db.Decimal(12, 2)
  status           String            @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  staff            Staff             @relation(fields: [staffId], references: [id], onDelete: Cascade)
}
